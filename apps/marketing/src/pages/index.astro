    display: block;
  }

  .hero-provrow {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin-top: 2.6rem;
  }
  .hero-provrow-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-faint);
