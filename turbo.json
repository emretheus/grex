{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "PORT",
    "VITE_WS_URL",
    "VITE_DEV_SERVER_URL",
    "ELECTRON_RENDERER_PORT",
    "CODEWIT_HOME",
    "CODEWIT_MODE",
    "CODEWIT_PORT",
    "CODEWIT_HOST",
    "CODEWIT_NO_BROWSER",
    "CODEWIT_AUTH_TOKEN",
    "CODEWIT_DESKTOP_WS_URL",
    "CODEWIT_BROWSER_USE_PIPE_PATH",
    "CODEWIT_BROWSER_PERF",
    "CODEWIT_PROVIDER_RUNTIME_IDLE_STOP_MS",
    "CODEWIT_GROK_ACP_DEBUG",
    "CODEWIT_WEB_SOURCEMAP",
    "CODEWIT_SERVER_SOURCEMAP",
    "CODEWIT_DESKTOP_SOURCEMAP",
    "CODEWIT_LOG_WS_EVENTS",
    "CODEWIT_LOG_PROVIDER_EVENTS",
    "CODEWIT_AUTO_BOOTSTRAP_PROJECT_FROM_CWD"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "dist-electron/**"]
    },
    "dev": {
      "dependsOn": ["@t3tools/contracts#build"],
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": [],
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": []
    }
  }
}
