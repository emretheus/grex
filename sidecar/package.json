{
	"name": "@grex/sidecar",
	"description": "Grex's agent-orchestration sidecar process (Claude Agent SDK + Codex SDK).",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "GREX_STAGE_CURSOR_WORKER=1 bun run scripts/stage-vendor.ts && bun run scripts/build.ts",
		"dev:prepare": "bun run stage-vendor && bun run build:worker",
		"stage-vendor": "bun run scripts/stage-vendor.ts",
		"build:worker": "bun run scripts/build-worker.ts",
		"dev": "bun run src/index.ts",
		"test": "bun test",
		"typecheck": "bunx tsc --noEmit"
	},
	"dependencies": {
		"@anthropic-ai/claude-agent-sdk": "0.3.186",
		"@anthropic-ai/claude-code": "2.1.186",
		"@cursor/sdk": "1.0.19",
		"@openai/codex": "0.142.0",
		"@opencode-ai/sdk": "1.17.9",
		"opencode-ai": "1.17.9"
	},
	"devDependencies": {
		"@types/bun": "^1.3.11",
		"@types/node": "^25.5.2"
	},
	"trustedDependencies": [
		"@anthropic-ai/claude-code"
	]
}
